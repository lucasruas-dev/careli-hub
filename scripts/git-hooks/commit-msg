#!/bin/sh
# Panteon git hook (resiliente, VERSIONADO). Ver nota no pre-commit.
RUNNER="scripts/panteon-hook-runner.ps1"

[ -f "$RUNNER" ] || exit 0

if command -v pwsh >/dev/null 2>&1 && pwsh -NoLogo -NoProfile -Command "exit 0" >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$RUNNER" -Hook commit-msg -CommitMsgFile "$1"
else
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$RUNNER" -Hook commit-msg -CommitMsgFile "$1"
fi
