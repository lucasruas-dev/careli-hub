#!/bin/sh
# Panteon git hook (resiliente, VERSIONADO). Ative com: pwsh scripts/setup-git-hooks.ps1
# (ou: git config core.hooksPath scripts/git-hooks)
#
# Historico: o runner scripts/panteon-hook-runner.ps1 foi perdido por volta de
# 2026-05-23. Enquanto ele NAO existir, o hook nao deve bloquear commits.
# Se o runner voltar a existir, a validacao reativa automaticamente.
RUNNER="scripts/panteon-hook-runner.ps1"

[ -f "$RUNNER" ] || exit 0

if command -v pwsh >/dev/null 2>&1 && pwsh -NoLogo -NoProfile -Command "exit 0" >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$RUNNER" -Hook pre-commit
else
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$RUNNER" -Hook pre-commit
fi
