# Careli Hub - exemplo de variaveis para homologacao.
# Copie estes nomes para o ambiente Preview/Custom Environment da Vercel.
# Nunca preencha secrets neste arquivo.

NEXT_PUBLIC_CARELI_APP_ENV=homologacao
NEXT_PUBLIC_CARELI_APP_URL=https://homolog.c2x.app.br
NEXT_PUBLIC_APP_URL=https://homolog.c2x.app.br
NEXT_PUBLIC_CARELI_ENABLE_MOCKS=false

# Supabase homologacao. Preferir projeto Supabase separado de producao.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_WORKSPACE_ID=careli
SUPABASE_SERVICE_ROLE_KEY=

# Integracoes externas em homologacao devem usar sandbox, teste ou permanecer vazias.
ASAAS_API_BASE_URL=
ASAAS_API_KEY=
D4SIGN_CRYPT_KEY=
D4SIGN_TOKEN_API=
GUARDIAN_SYNC_SECRET=
OPENAI_API_KEY=

# Banco C2X/Guardian: usar replica/homologacao quando existir.
GUARDIAN_DB_HOST=
GUARDIAN_DB_PORT=
GUARDIAN_DB_NAME=
GUARDIAN_DB_USER=
GUARDIAN_DB_PASSWORD=
GUARDIAN_DB_SSL=

# Modelos IA server-side.
HUB_AI_MODEL=
HUB_IT_TICKET_TRANSCRIPTION_MODEL=
