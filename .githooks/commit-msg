#!/bin/sh

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "scripts/panteon-hook-runner.ps1" -Hook commit-msg -CommitMsgFile "$1"
else
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "scripts/panteon-hook-runner.ps1" -Hook commit-msg -CommitMsgFile "$1"
fi
