# Garante que as devDependencies (turbo, next, typescript, tailwind) sejam
# instaladas no build da Vercel mesmo com NODE_ENV=production. Sem isso o
# `npm install` poda as devDeps, o `turbo` some e o build falha com
# "Could not resolve workspaces". O npm le este arquivo SEMPRE (independe de
# installCommand/buildCommand do vercel.json, que a Vercel aplica de forma
# inconsistente em deploy via CLI). Ver memoria: project-deploy-recipe.
production=false
