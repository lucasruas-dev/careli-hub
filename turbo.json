    "CRON_SECRET",
    "D4SIGN_CRYPT_KEY",
    "D4SIGN_TOKEN_API",
    "GOOGLE_CALENDAR_PRIMARY_CALENDAR_ID",
    "GOOGLE_CALENDAR_SCOPES",
    "GUARDIAN_DB_HOST",
    "GUARDIAN_DB_NAME",
    "GUARDIAN_DB_PASSWORD",
    "GUARDIAN_DB_PORT",
    "GUARDIAN_DB_SSL",
