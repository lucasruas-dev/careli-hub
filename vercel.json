{
  "buildCommand": "npm install --include=dev && npx turbo build --filter=@repo/hub",
  "installCommand": "npm install --include=dev",
  "outputDirectory": "apps/hub/.next",
  "crons": [
    {
      "path": "/api/chronos/recordings/egress-cron",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/chronos/google-calendar/sync-cron",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/guardian/sync/c2x",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/apolo/sync/c2x",
      "schedule": "20 */6 * * *"
    },
    {
      "path": "/api/apolo/sync/c2x/incremental",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/guardian/lembretes/cron",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/notifications/sweep",
      "schedule": "*/15 * * * *"
    }
  ]
}
