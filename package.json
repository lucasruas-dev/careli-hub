{
  "name": "careli-hub",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "deploy:homolog": "powershell -ExecutionPolicy Bypass -File scripts/deploy-homologation.ps1",
    "healthcheck:homolog": "powershell -ExecutionPolicy Bypass -File scripts/homologation-healthcheck.ps1",
    "lint": "turbo run lint",
    "lint:hub": "turbo run lint --filter=@repo/hub...",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "squadops:sync": "node scripts/squadops-sync-operations-watch.mjs --once",
    "squadops:sync:watch": "node scripts/squadops-sync-operations-watch.mjs --watch",
    "deploy:prod:gate": "node scripts/panteon-production-recorte-gate.mjs",
    "deploy:prod:gate:self-test": "node scripts/panteon-production-recorte-gate.mjs --self-test",
    "check-types": "turbo run check-types",
    "check-types:hub": "turbo run check-types --filter=@repo/hub...",
    "validate:hub": "npm run check-types:hub && npm run lint:hub && npm run build --workspace @repo/hub"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.12",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
