# Public app metadata used by the Hub app.
NEXT_PUBLIC_CARELI_APP_ENV=preview
NEXT_PUBLIC_CARELI_APP_URL=https://careli-hub.example.com
NEXT_PUBLIC_CARELI_ENABLE_MOCKS=true

# Supabase Auth is optional. Leave blank to use the local mock auth fallback.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Required for Setup Central to create Supabase Auth users.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Required for Careli AI.
OPENAI_API_KEY=
HUB_AI_MODEL=gpt-5.5

# Server-only. Required to generate fresh signed contract download links from D4Sign.
D4SIGN_TOKEN_API=
D4SIGN_CRYPT_KEY=
