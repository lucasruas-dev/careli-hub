# Public app metadata used by the Hub app.
NEXT_PUBLIC_CARELI_APP_ENV=preview
NEXT_PUBLIC_CARELI_APP_URL=https://careli-hub.example.com
NEXT_PUBLIC_CARELI_ENABLE_MOCKS=true

# Supabase Auth is optional. Leave blank to use the local mock auth fallback.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Required for Setup Central to create Supabase Auth users.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Required for Careli AI.
OPENAI_API_KEY=
HUB_AI_MODEL=gpt-5.5

# Chronos video calls. Keep the Whereby API key server-side only.
CHRONOS_VIDEO_PROVIDER=whereby
WHEREBY_API_KEY=
WHEREBY_API_BASE_URL=https://api.whereby.dev/v1
CHRONOS_WHEREBY_RECORDING_START_TRIGGER=automatic-2nd-participant
CHRONOS_WHEREBY_TRANSCRIPTION_START_TRIGGER=automatic-2nd-participant
CHRONOS_WHEREBY_TRANSCRIPTION_LANGUAGE=pt-BR
NEXT_PUBLIC_CHRONOS_WHEREBY_EMBED_SCRIPT_URL=https://cdn.srv.whereby.com/embed/v3-embed.js

# Server-only. Required to generate fresh signed contract download links from D4Sign.
D4SIGN_TOKEN_API=
D4SIGN_CRYPT_KEY=

# Server-only. Required for Iris Meta WhatsApp Cloud API.
# Never expose these values in NEXT_PUBLIC_* variables.
META_WHATSAPP_APP_ID=
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=
META_WHATSAPP_GRAPH_VERSION=
